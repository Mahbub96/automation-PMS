NODE_ENV=production
PORT=3000
TIMEZONE=Asia/Dhaka
DAILY_CRON=25 10 * * *

ATTENDANCE_API_URL=https://your-attendance-api
ATTENDANCE_API_TODAY_PATH=/api/brotecs/today-dashboard
# Option A (legacy/static token): direct bearer token
ATTENDANCE_API_KEY=
# Option B (recommended): login to get access token automatically
ATTENDANCE_AUTH_URL=https://your-attendance-api/api/auth/login/
ATTENDANCE_USERNAME=replace_with_username
ATTENDANCE_PASSWORD=replace_with_password
ATTENDANCE_TOKEN_CACHE_FILE=.cache/attendance-api-token.json
ATTENDANCE_TIMEOUT_MS=10000
ATTENDANCE_MAX_RETRIES=3

API_AUTH_REQUIRED=true
API_AUTH_TOKEN=replace_with_long_random_api_token

# Frontend Firebase Web SDK (UI mode)
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_API_TOKEN=
VITE_API_BASE_URL=https://your-api-host
VITE_FORCE_FIREBASE_MODE=false
VITE_WA_TRACK_SSE_URL=http://localhost:3099/events
VITE_AUTO_APPLY_HOUR=17
VITE_AUTO_APPLY_CHECK_INTERVAL_MS=30000
VITE_TRACK_FALLBACK_REFRESH_MS=5000
VITE_DONE_CUTOFF_HOUR=10
VITE_DONE_CUTOFF_MINUTE=25
VITE_LATE_DONE_WATCH_MINUTES=10
VITE_DISPUTE_REQUIRED_DONE_COUNT=1
VITE_DISPUTE_CACHE_RETENTION_HOURS=12
VITE_DEFAULT_PENALTY_AMOUNT=100
VITE_LATE_DONE_REASON_TEXT=Late done related one issues
VITE_DEFAULT_REASON_ID=

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
# Optional alternatives if not using FIREBASE_SERVICE_ACCOUNT_PATH:
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiB...

WHATSAPP_GROUP_ID=1203630xxxxxxxxx@g.us
WHATSAPP_AUTH_PATH=.wwebjs_auth
WHATSAPP_LOGIN_TIMEOUT_MS=600000
WHATSAPP_SESSION_SECRET=replace_with_long_random_secret
WA_TRACK_CACHE_FILE=ui/public/wa-track-events.json
WA_TRACK_SSE_PORT=3099
WA_TRACK_RETENTION_HOURS=12
WA_TRACK_PRUNE_INTERVAL_MS=600000
WA_TRACK_MAX_ITEMS=1000
# Optional legacy aliases (if set, can be used by tracker/UI cutoff fallback):
# WA_DONE_CUTOFF_HOUR=10
# WA_DONE_CUTOFF_MINUTE=25

STARTUP_RETRY_ENABLED=false
