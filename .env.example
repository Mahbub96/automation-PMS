NODE_ENV=development
PORT=3000
TIMEZONE=Asia/Dhaka
DAILY_CRON=25 10 * * *

ATTENDANCE_API_URL=https://example-attendance-api.com/present-users
ATTENDANCE_API_KEY=replace_with_api_key
ATTENDANCE_TIMEOUT_MS=10000
ATTENDANCE_MAX_RETRIES=3

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
# Optional safer alternative (base64 encoded PEM content):
# FIREBASE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0tCg...

WHATSAPP_GROUP_ID=1203630xxxxxxxxx@g.us
WHATSAPP_AUTH_PATH=.wwebjs_auth
WHATSAPP_SESSION_SECRET=replace_with_long_random_secret
